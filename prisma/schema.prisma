// Prisma schema for VariationVault - Australian tradie estimation app

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Variation {
  id              String    @id @default(cuid())
  projectId       String
  projectName     String
  clientName      String
  clientEmail     String
  clientPhone     String
  address         String
  suburb          String
  state           String
  postcode        String
  projectRefId    String?   @map("project_ref_id")
  description     String
  measurements    String
  totalArea       String
  items           String
  totalLabor      Float
  totalMaterials  Float
  tax             Float
  total           Float
  notes           String?
  status          String    @default("DRAFT") // DRAFT, SENT, CLIENT_REVIEW, APPROVED, REJECTED, COMPLETED
  approvalStatus  ApprovalStatus @default(PENDING)
  pdfUrl          String?
  version         Int       @default(1)
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project?  @relation(fields: [projectRefId], references: [id], onDelete: SetNull)
  versionHistory  VariationVersion[]
  approvals       Approvals[]
  notifications   Notifications[]
  
  @@index([projectRefId])
  @@map("variations")
}

model Client {
  id        String    @id @default(cuid())
  name      String
  email     String
  phone     String
  company   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]

  @@index([email])
  @@map("clients")
}

model Project {
  id         String      @id @default(cuid())
  clientId   String
  code       String
  name       String
  address    String
  suburb     String
  state      String
  postcode   String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  variations Variation[]

  @@index([clientId])
  @@map("projects")
}

model VariationVersion {
  id          String            @id @default(cuid())
  variationId String
  version     Int
  images      String[]          @default([])
  changes     String
  updatedAt   DateTime          @default(now())
  variation    Variation        @relation(fields: [variationId], references: [id], onDelete: Cascade)
  
  @@index([variationId])
  @@map("variation_versions")
}

model Approvals {
  id          String             @id @default(cuid())
  variationId String
  clientId    String?
  email       String
  status      ApprovalStatus     @default(PENDING)
  comments    String?
  notified    Boolean            @default(false)
  notifiedAt  DateTime?
  ipAddr      String?
  userAgent   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  variation   Variation          @relation(fields: [variationId], references: [id], onDelete: Cascade)
  
  @@index([variationId])
  @@index([status])
  @@map("approvals")
}

model Notifications {
  id        String             @id @default(cuid())
  variationId String
  type      String           // EMAIL, SMS, WHATSAPP
  status    NotificationStatus @default(PENDING)
  recipient String
  message   String?
  error     String?
  tries     Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  variation Variation      @relation(fields: [variationId], references: [id], onDelete: Cascade)
  
  @@map("notifications")
}

model Settings {
  id           String  @id @default(cuid())
  company      String
  email        String?
  smsProvider  String?
  emailProvider String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@map("settings")
}

model Users {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("tradies") // admin, tradie
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
